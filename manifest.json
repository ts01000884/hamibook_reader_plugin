{
  "manifest_version": 3,
  "name": "HamiBook 朗讀 + 夜間模式",
  "version": "1.7.0",
  "description": "HamiBook WebReader 中文朗讀（播完自動翻頁接續）＋全文段落進度紀錄＋UI 黑夜模式。",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://webreader.hamibook.com.tw/viewer/*"
      ],
      "js": ["main.js"],
      "run_at": "document_start",
      "all_frames": false,
      "world": "MAIN"
    }
  ]
}
